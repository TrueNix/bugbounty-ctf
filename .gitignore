# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Security testing state (never commit)
.hermes/
~/.hermes/
/tmp/callbacks.log
security_state.json
security_reports/

# Engagement memory (never commit — holds live target findings/secrets).
# The runtime KB defaults to ~/.hermes/knowledge.db (already ignored above).
# Any stray knowledge.db / scanner.db in the tree is ALSO ignored...
knowledge.db
scanner.db
*.scanner.db
# ...EXCEPT the curated, secret-free reference index we ship on purpose:
!data/reference_knowledge.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
.omo/
